# Exact public browser origin. Paths are normalized away; wildcards are rejected.
LANDING_PUBLIC_URL=https://doligrid.com

# Optional comma-separated exact origins for explicitly approved aliases/previews.
# Local development is allowed only when listed here (or used as LANDING_PUBLIC_URL).
ALLOWED_LANDING_ORIGINS=

# Core origin or a URL ending in /api/v1.
CORE_API_URL=https://manager.frametoy.online/api/v1
PRODUCT_SLUG=doligrid

# Server-only. Use the same value configured in Manager Admin → Settings.
# Never prefix this variable with NEXT_PUBLIC_.
PLATFORM_API_KEY=<server-only-platform-api-key>

# Paddle.js overlay checkout (client-side token from Paddle → Developer tools).
# Use sandbox token + NEXT_PUBLIC_PADDLE_ENV=sandbox while testing.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox

# Optional: Client Portal base URL shown on /checkout/success.
# PORTAL_URL=https://manager.example.com
# NEXT_PUBLIC_PORTAL_URL=https://manager.example.com
